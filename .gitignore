# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# ── Virtualenv ────────────────────────────────────────────────────────────────
netenv/

# ── Data ──────────────────────────────────────────────────────────────────────
data/

